{
  "expo": {
    "name": "Minha Copa 2026",
    "slug": "minha-copa2026-app",
    "version": "1.0.0-beta",
    "orientation": "portrait",
    "icon": "./assets/images/app-logo.png",
    "userInterfaceStyle": "automatic",
    "scheme": "minhacopa2026",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.andreygarcia.minhacopa2026"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/app-logo.png"
      },
      "package": "br.com.andreygarcia.minhacopa2026",
      "versionCode": 9,
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/images/app-logo.png",
      "bundler": "metro"
    },
    "androidNavigationBar": {
      "enforceContrast": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": false,
          "recordAudioAndroid": false
        }
      ],
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/app-splash.png",
          "imageWidth": 200,
          "resizeMode": "cover"
        }
      ],
      "./plugins/withRemoveAudioPermissions.js"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bf7a94e9-13e9-44d9-80e4-2d89b470d1bb"
      }
    },
    "owner": "dedeygarcia"
  }
}
