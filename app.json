{
  "expo": {
    "name": "Minha Copa 2026",
    "slug": "rbr-album-copa2026-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-logo.png",
    "userInterfaceStyle": "automatic",
    "scheme": "minhacopa2026",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.robotics.albumcopa2026"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/app-logo.png"
      },
      "package": "br.com.robotics.albumcopa2026",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/images/app-logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/app-splash.png",
          "imageWidth": 200,
          "resizeMode": "cover"
        }
      ],
      [
        "expo-navigation-bar",
        {
          "enforceContrast": false
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "77d693d7-a5cc-49b1-9d27-eaee07c6d9dd"
      }
    },
    "owner": "dedeygarcia"
  }
}
