{
  "expo": {
    "name": "Minha Copa 2026",
    "slug": "rbr-album-copa2026-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-logo.jpeg",
    "userInterfaceStyle": "automatic",
    "scheme": "minhacopa2026",
    "splash": {
      "image": "./assets/images/app-splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.robotics.albumcopa2026"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/app-logo.jpeg"
      },
      "package": "br.com.robotics.albumcopa2026",
      "permissions": ["android.permission.RECORD_AUDIO", "android.permission.MODIFY_AUDIO_SETTINGS"]
    },
    "web": {
      "favicon": "./assets/images/app-logo.jpeg",
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-audio", "expo-asset"],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dbd18b05-a06e-4480-a431-24cb1698c7fd"
      }
    }
  }
}
