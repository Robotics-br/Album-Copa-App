{
  "name": "rbr-album-copa2026-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "adb kill-server && expo start --tunnel -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "prebuild": "npx expo prebuild --clean",
    "build:android:prod:local": "eas build --platform android --profile production --local",
    "build:android:debug:apk": "cd android && gradlew assembleRelease && copy app\\build\\outputs\\apk\\release\\app-release.apk ..\\app-release.apk",
    "build:android:preview:cloud": "eas build --platform android --profile preview",
    "build:ios:preview:cloud": "eas build --platform ios --profile preview",
    "build:android:prod:cloud": "eas build --platform android --profile production",
    "build:all:prod:cloud": "eas build --platform all --profile production"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/flash-list": "2.0.2",
    "axios": "^1.13.6",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-audio": "~1.1.1",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-navigation-bar": "~5.0.10",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "i18next": "^25.8.17",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.2.2",
    "react": "19.1.0",
    "react-i18next": "^16.5.6",
    "react-native": "0.81.5",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.3.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
